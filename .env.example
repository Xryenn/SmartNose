# Supabase Configuration
# Copy this file to .env.local and fill in your Supabase credentials

# Your Supabase project URL
# Get this from: https://app.supabase.com/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Your Supabase anon/public API key
# Get this from: https://app.supabase.com/project/YOUR_PROJECT/settings/api
SUPABASE_ANON_KEY=your_anon_public_key_here

# Optional: Supabase service role key (use only in secure backend)
# Get this from: https://app.supabase.com/project/YOUR_PROJECT/settings/api
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
